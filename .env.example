# ⚙️ HawkEye Shield Configuration

# === Birdeye Data API ===
BIRDEYE_API_KEY=your_birdeye_api_key_here

# === Solana Blockchain ===
SOLANA_PRIVATE_KEY=your_base58_private_key_here
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WRITE_RPC_URL=https://api.mainnet-beta.solana.com

# === Trading Parameters & Position Sizing ===
# If USE_DYNAMIC_SIZING=true, bot buys using % of wallet (KELLY_FRACTION). 
# If false, it buys exactly TRADE_SIZE_SOL.
USE_DYNAMIC_SIZING=true
KELLY_FRACTION=0.15
TRADE_SIZE_SOL=0.05
TAKE_PROFIT_PERCENT=40
STOP_LOSS_PERCENT=12
SLIPPAGE_BPS=250
MAX_ACTIVE_TRADES=2

# === Jupiter Swap ===
JUPITER_API_KEY=
USE_JUPITER_ULTRA=true
PRIORITY_FEE_MICRO_LAMPORTS=1000000

# === Mode ===
# true = Paper Trade (Simulated trading, no real TX)
# false = Live Trade (Real trading with real SOL!)
PAPER_TRADE=true
