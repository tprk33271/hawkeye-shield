# 🦅 HawkEye Shield - Environment Configuration
# Copy this to .env and fill in your values

# ─── API KEYS ────────────────────────────────────────────────
# Get BirdEye API Key: https://docs.birdeye.so/docs/authentication
BIRDEYE_API_KEY=your_birdeye_api_key_here

# (Optional) Jupiter API Key for faster quotes
JUPITER_API_KEY=your_jupiter_api_key_here

# ─── SOLANA WALLET ──────────────────────────────────────────
# Base58 format (e.g., Phantom exported private key)
SOLANA_PRIVATE_KEY=your_base58_private_key_here

# ─── RPC NODES ──────────────────────────────────────────────
# Helius, QuickNode, or Triton recommended for live trading
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WRITE_RPC_URL=https://api.mainnet-beta.solana.com

# ─── TRADING STRATEGY ───────────────────────────────────────
# Amount of SOL to spend per trade
TRADE_SIZE_SOL=0.01

# Dynamic sizing uses Kelly Criterion (Advanced)
USE_DYNAMIC_SIZING=true
KELLY_FRACTION=0.15

# Profit/Loss thresholds (in percent)
TAKE_PROFIT_PERCENT=40
STOP_LOSS_PERCENT=12

# Slippage in Basis Points (100 = 1%)
SLIPPAGE_BPS=250

# Maximum number of concurrent trades
MAX_ACTIVE_TRADES=2

# ─── EXECUTION SETTINGS ─────────────────────────────────────
# Use Jupiter Ultra API (requires JUPITER_API_KEY)
USE_JUPITER_ULTRA=false

# Priority fee to beat bots (in micro lamports)
# 1,000,000 = 0.001 SOL per transaction
PRIORITY_FEE_MICRO_LAMPORTS=1000000

# ─── OPERATING MODE ─────────────────────────────────────────
# Set to 'false' for live trading with real SOL
PAPER_TRADE=true
